{
  "name": "cachepuppy-cli",
  "version": "0.3.0",
  "description": "CLI for running CachePuppy locally with Docker Compose",
  "license": "MIT",
  "type": "module",
  "bin": {
    "cachepuppy": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "enquirer": "^2.4.1",
    "execa": "^9.5.1",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
