PORT=8787
CACHEPUPPY_API_BASE=http://127.0.0.1:4000
# URL CachePuppy step executor uses to call back into this server (must be reachable from CachePuppy node)
# Local phoenix: http://127.0.0.1:8787
# Docker phoenix on Docker Desktop: http://host.docker.internal:8787
WORKFLOW_DEMO_PUBLIC_URL=http://host.docker.internal:8787
# Artificial delay per scenario endpoint in milliseconds (for visible step-by-step UI progression)
WORKFLOW_STEP_DELAY_MS=5000
