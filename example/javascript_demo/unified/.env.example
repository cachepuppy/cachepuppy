# --- Browser-visible (must be prefixed NEXT_PUBLIC_) -----------------------
# Phoenix websocket URL used by the React SDK in the browser.
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:4000/socket/websocket

# --- Server-only -----------------------------------------------------------
# CachePuppy HTTP origin used by the admin client inside Next.js API routes.
CACHEPUPPY_API_BASE=http://127.0.0.1:4000

# Public URL the CachePuppy server uses to call back into this Next.js app
# for workflow step HTTP callbacks. If Phoenix runs in Docker on macOS,
# use http://host.docker.internal:3000.
WORKFLOW_DEMO_PUBLIC_URL=http://127.0.0.1:3000

# Artificial delay added to each workflow step (helps visualise the graph).
WORKFLOW_STEP_DELAY_MS=5000
